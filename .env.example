# AI-Driven Design Review Agent
# Environment Configuration Template

# Copy this file to .env and fill in your values
# DO NOT commit the .env file to version control

# ============================================
# Jira Configuration
# ============================================
JIRA_URL=https://your-organization.atlassian.net
JIRA_USERNAME=your-email@organization.com
JIRA_API_TOKEN=your-api-token-here

# ============================================
# Confluence Configuration
# ============================================
CONFLUENCE_URL=https://your-organization.atlassian.net/wiki
CONFLUENCE_USERNAME=your-email@organization.com
CONFLUENCE_API_TOKEN=your-api-token-here

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ============================================
# GitHub Configuration (Optional)
# ============================================
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_ORG=your-organization
GITHUB_REPO=design-jira-agent

# ============================================
# AWS Configuration (Optional)
# ============================================
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# ============================================
# Azure Configuration (Optional)
# ============================================
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_STORAGE_ACCOUNT=your-storage-account

# ============================================
# Application Configuration
# ============================================
APP_ENV=development  # development, staging, production
APP_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
APP_DEBUG=false

# ============================================
# Review Configuration
# ============================================
REVIEW_SEVERITY_THRESHOLD=medium
INCLUDE_AUDIT_TRAIL=true
REPORT_FORMAT=markdown
PARALLEL_AGENT_EXECUTION=true

# ============================================
# Proxy Configuration (If needed)
# ============================================
# HTTP_PROXY=http://proxy.organization.com:8080
# HTTPS_PROXY=https://proxy.organization.com:8080
# NO_PROXY=localhost,127.0.0.1

# ============================================
# Notification Configuration
# ============================================
# SMTP_SERVER=smtp.organization.com
# SMTP_PORT=587
# SMTP_USERNAME=notifications@organization.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=notifications@organization.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Security Configuration
# ============================================
JWT_SECRET_KEY=your-secret-key-for-jwt
API_KEY=your-api-key-for-protected-endpoints

# ============================================
# Performance Configuration
# ============================================
CACHE_TTL=3600
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=60

# ============================================
# Paths and Directories
# ============================================
REPORTS_DIR=./reports
LOGS_DIR=./logs
DATA_DIR=./data
CACHE_DIR=./.cache

# ============================================
# Feature Flags
# ============================================
ENABLE_SECURITY_REVIEW=true
ENABLE_SCALABILITY_REVIEW=true
ENABLE_COMPLIANCE_CHECK=true
ENABLE_DIAGRAM_ANALYSIS=false

# ============================================
# Custom Rules
# ============================================
CUSTOM_RULES_ENABLED=false
CUSTOM_RULES_FILE=./config/custom_rules.yaml
DOMAIN_SPECIFIC_CRITERIA=fintech
